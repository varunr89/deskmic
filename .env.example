# deskmic environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — only .env.example is tracked.

# Azure OpenAI (Whisper transcription + embeddings)
DESKMIC_AZURE_ENDPOINT=
DESKMIC_AZURE_KEY=
DESKMIC_AZURE_WHISPER_DEPLOYMENT=whisper
DESKMIC_AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
DESKMIC_AZURE_CHAT_DEPLOYMENT=gpt-5.3-chat

# Azure Communication Services (email summaries)
DESKMIC_ACS_ENDPOINT=
DESKMIC_ACS_KEY=
DESKMIC_ACS_SENDER=
DESKMIC_ACS_RECIPIENT=

# Azure Blob Storage (transcript + DB sync)
DESKMIC_BLOB_ACCOUNT=
DESKMIC_BLOB_CONTAINER=deskmic
DESKMIC_BLOB_SAS_RW=
DESKMIC_BLOB_SAS_RO=

# Output directory (where recordings, transcripts, and search DB live)
DESKMIC_OUTPUT_DIR=
